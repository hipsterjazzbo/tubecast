# TubeCast configuration — optional for deploy (docker-compose.yml has defaults).
# Copy to `.env` to override settings; Compose reads it automatically.
# For development, run `make setup` to create this file with an interactive admin password.
# Run tests on the host with `composer test` (phpunit.xml overrides DB paths).

# --- Compose (host) ---
TUBECAST_PORT=8742

# File ownership inside the container (Debian www-data default: 33).
# Set to your TrueNAS apps user/group (e.g. 568:568) so /data matches host volume permissions.
PUID=33
PGID=33

# --- App ---
# Possible values: local, staging, production, ci, testing, other
ENVIRONMENT=local

# SIGNING_KEY is auto-generated on first container start and stored in the data volume.
# Do not set SIGNING_KEY here — an empty value breaks sessions.

# Base URI for RSS enclosures and media URLs
BASE_URI=http://localhost:8742

# Admin login (default password is "changeme" — change before exposing to a network)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

INTERNAL_CACHES=true
DISCOVERY_CACHE=partial

DEBUG_LOG_PATH=null
SERVER_LOG_PATH=null

# --- Data (Docker volume paths; for native PHP use data/ and database/database.sqlite) ---
DB_DATABASE=/data/database.sqlite
DATA_PATH=/data
DOWNLOADS_PATH=/data/downloads
PODCAST_PATH=/data/podcast

# --- yt-dlp (also configurable in Settings UI: cookies, proxy) ---
YT_DLP_BINARY=yt-dlp
YT_DLP_WORKER_CONCURRENCY=1
YT_DLP_SLEEP_INTERVAL=5
YT_DLP_SLEEP_REQUESTS=1
YT_DLP_LIMIT_RATE=

# --- YouTube Data API (optional; can also be saved in Settings UI) ---
YOUTUBE_API_KEY=

# --- Container runtime (FrankenPHP/Caddy; not read by Tempest) ---
SERVER_NAME=:8080
