# TubeCast — lerd local development
# Copy to .env, then run: lerd env_setup && lerd setup
#
# Docker deploy does not use this file. See .env.docker.example for optional
# Compose overrides, or just run: docker compose up -d

# --- App ---
# Possible values: local, staging, production, ci, testing, other
ENVIRONMENT=local

# lerd env_setup rewrites BASE_URI from the site URL (https://tubecast.test when secured)
BASE_URI=https://tubecast.test

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

INTERNAL_CACHES=true
DISCOVERY_CACHE=partial

DEBUG_LOG_PATH=null
SERVER_LOG_PATH=null

# --- Data (host paths, relative to project root) ---
DB_DATABASE=database/database.sqlite
DATA_PATH=data
VIDEO_PATH=data/video
AUDIO_PATH=data/audio

# --- yt-dlp (also configurable in Settings UI: cookies, proxy) ---
# tubecast:init may set this to data/bin/yt-dlp when no system binary is found
YT_DLP_BINARY=yt-dlp
YT_DLP_WORKER_CONCURRENCY=1
YT_DLP_SLEEP_INTERVAL=5
YT_DLP_SLEEP_REQUESTS=1
YT_DLP_LIMIT_RATE=

# --- YouTube Data API (optional; can also be saved in Settings UI) ---
YOUTUBE_API_KEY=
