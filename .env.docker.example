# Optional Docker Compose overrides — copy to .env.docker
#
# Fresh install needs no env file:
#   docker compose up -d
#
# To customize, copy this file and pass it to Compose (TUBECAST_* prefix avoids
# conflicting with a lerd .env in the same directory):
#   cp .env.docker.example .env.docker
#   docker compose --env-file .env.docker up -d

TUBECAST_PORT=8742

# File ownership inside the container (Debian www-data default: 33).
# Set to your NAS volume owner (e.g. 568:568 on TrueNAS).
TUBECAST_PUID=33
TUBECAST_PGID=33

TUBECAST_BASE_URI=http://localhost:8742
TUBECAST_ADMIN_USERNAME=admin
TUBECAST_ADMIN_PASSWORD=changeme

TUBECAST_YOUTUBE_API_KEY=
